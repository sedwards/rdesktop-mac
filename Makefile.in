#
# rdesktop: A Remote Desktop Protocol client
# Makefile.in
# Copyright (C) Matthew Chapman 1999-2007
#

prefix      = @prefix@
exec_prefix = @exec_prefix@
bindir      = @bindir@
mandir      = @mandir@
datarootdir = @datarootdir@
datadir     = @datadir@

VERSION     = @PACKAGE_VERSION@
KEYMAP_PATH = $(datadir)/rdesktop/keymaps/

CC          = @CC@
INSTALL     = @INSTALL@
CFLAGS      = @CFLAGS@ @DEFS@ -DKEYMAP_PATH=\"$(KEYMAP_PATH)\" -DUSE_OPENSSL -I./deps/openssl_build/include
LDFLAGS     = @LDFLAGS@ @LIBS@ -L./deps/openssl_build/lib -lssl -lcrypto
STRIP       = @STRIP@

TARGETS     = rdesktop-mac
SOUNDOBJ    = @SOUNDOBJ@
SCARDOBJ    = @SCARDOBJ@
CREDSSPOBJ  = @CREDSSPOBJ@

RDPOBJ   = tcp.o asn.o iso.o mcs.o secure.o licence.o orders.o bitmap.o cache.o rdp5.o channels.o rdpdr.o serial.o printer.o disk.o parallel.o printercache.o mppc.o pstcache.o lspci.o seamless.o macssl.o utils.o stream.o dvc.o rdpedisp.o
MACOBJ   = mac_gui_main.o rdesktop_main.o rdp.o macwin.o mackeymap.o macclip.o MacRDPConnectionGUI.o cliprdr.o ctrl.o

.PHONY: all
all: $(TARGETS)

rdesktop-mac: $(MACOBJ) $(SOUNDOBJ) $(RDPOBJ) $(SCARDOBJ) $(CREDSSPOBJ)
	$(CC) $(CFLAGS) -o rdesktop-mac $(MACOBJ) $(SOUNDOBJ) $(RDPOBJ) $(SCARDOBJ) $(CREDSSPOBJ) $(LDFLAGS) -framework Cocoa -framework CoreGraphics -framework Carbon -framework Security

.PHONY: install
install: installbin installkeymaps installman

.PHONY: installbin
installbin: rdesktop-mac
	mkdir -p $(DESTDIR)$(bindir)
	$(INSTALL) rdesktop-mac $(DESTDIR)$(bindir)
	$(STRIP) $(DESTDIR)$(bindir)/rdesktop-mac
	chmod 755 $(DESTDIR)$(bindir)/rdesktop-mac

.PHONY: installman
installman: doc/rdesktop.1
	mkdir -p $(DESTDIR)$(mandir)/man1
	cp doc/rdesktop.1 $(DESTDIR)$(mandir)/man1
	chmod 644 $(DESTDIR)$(mandir)/man1/rdesktop.1

.PHONY: installkeymaps
installkeymaps:
	mkdir -p $(DESTDIR)$(KEYMAP_PATH)
# Prevent copying the CVS directory
	cp keymaps/?? keymaps/??-?? keymaps/??-??-???? $(DESTDIR)$(KEYMAP_PATH)
	cp keymaps/common $(DESTDIR)$(KEYMAP_PATH)
	cp keymaps/modifiers $(DESTDIR)$(KEYMAP_PATH)
	chmod 644 $(DESTDIR)$(KEYMAP_PATH)/*

.PHONY: clean
clean:
	rm -f *.o *~ rdesktop-mac rdesktop
	rm -rf 3rdparty/*.o 3rdparty/*/*.o 3rdparty/*/*.a 3rdparty/*/*.la rdesktop-mac.app

.PHONY: bundle
bundle: rdesktop-mac
	rm -rf rdesktop-mac.app
	mkdir -p rdesktop-mac.app/Contents/MacOS
	mkdir -p rdesktop-mac.app/Contents/Resources
	cp rdesktop-mac rdesktop-mac.app/Contents/MacOS/
	mkdir -p rdesktop-mac.app/Contents/Resources/keymaps
	cp -R keymaps/ rdesktop-mac.app/Contents/Resources/keymaps/
	if [ -f Resources/rdesktop-mac.svg ]; then \
		qlmanage -t -s 512 -o . Resources/rdesktop-mac.svg; \
		clang -O2 -framework AppKit -framework Foundation make_icns.m -o make_icns; \
		./make_icns rdesktop-mac.svg.png rdesktop-mac.app/Contents/Resources/rdesktop-mac.icns; \
		rm -f make_icns rdesktop-mac.svg.png; \
	fi
	echo '<?xml version="1.0" encoding="UTF-8"?>' > rdesktop-mac.app/Contents/Info.plist
	echo '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">' >> rdesktop-mac.app/Contents/Info.plist
	echo '<plist version="1.0">' >> rdesktop-mac.app/Contents/Info.plist
	echo '<dict>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleDevelopmentRegion</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>English</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleExecutable</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>rdesktop-mac</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleIdentifier</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>com.rdesktop.rdesktop-mac</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleInfoDictionaryVersion</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>6.0</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleName</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>rdesktop-mac</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundlePackageType</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>APPL</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleShortVersionString</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>$(VERSION)</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleSignature</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>????</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleVersion</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>$(VERSION)</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>CFBundleIconFile</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>rdesktop-mac.icns</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>NSPrincipalClass</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <string>NSApplication</string>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <key>NSHighResolutionCapable</key>' >> rdesktop-mac.app/Contents/Info.plist
	echo '    <true/>' >> rdesktop-mac.app/Contents/Info.plist
	echo '</dict>' >> rdesktop-mac.app/Contents/Info.plist
	echo '</plist>' >> rdesktop-mac.app/Contents/Info.plist

.PHONY: distclean
distclean: clean
	rm -rf autom4te.cache config.log config.status Makefile rdesktop-$(VERSION).tar.gz

.PHONY: dist
dist: rdesktop-$(VERSION).tar.gz

rdesktop-$(VERSION).tar.gz: Makefile configure
	mkdir -p /tmp/rdesktop-make-dist-dir
	ln -sf `pwd` /tmp/rdesktop-make-dist-dir/rdesktop-$(VERSION)
	(cd /tmp/rdesktop-make-dist-dir; \
	tar zcvf rdesktop-$(VERSION)/rdesktop-$(VERSION).tar.gz \
	rdesktop-$(VERSION)/COPYING \
	rdesktop-$(VERSION)/README.md \
	rdesktop-$(VERSION)/configure \
	rdesktop-$(VERSION)/configure.ac \
	rdesktop-$(VERSION)/config.sub \
	rdesktop-$(VERSION)/config.guess \
	rdesktop-$(VERSION)/bootstrap \
	rdesktop-$(VERSION)/install-sh \
	rdesktop-$(VERSION)/Makefile.in \
	rdesktop-$(VERSION)/rdesktop.spec \
	rdesktop-$(VERSION)/*.c \
	rdesktop-$(VERSION)/*.h \
	rdesktop-$(VERSION)/keymaps/?? \
	rdesktop-$(VERSION)/keymaps/??-* \
	rdesktop-$(VERSION)/keymaps/common \
	rdesktop-$(VERSION)/keymaps/modifiers \
	rdesktop-$(VERSION)/keymaps/convert-map \
	rdesktop-$(VERSION)/doc/HACKING \
	rdesktop-$(VERSION)/doc/AUTHORS \
	rdesktop-$(VERSION)/doc/TODO \
	rdesktop-$(VERSION)/doc/ChangeLog \
	rdesktop-$(VERSION)/doc/keymapping.txt \
	rdesktop-$(VERSION)/doc/keymap-names.txt \
	rdesktop-$(VERSION)/doc/ipv6.txt \
	rdesktop-$(VERSION)/doc/licensing.txt \
	rdesktop-$(VERSION)/doc/patches.txt \
	rdesktop-$(VERSION)/doc/redirection.txt \
	rdesktop-$(VERSION)/doc/rdesktop.1 )
	rm -rf /tmp/rdesktop-make-dist-dir

.PHONY: dist-noversion
dist-noversion: rdesktop.tar.gz

rdesktop.tar.gz: rdesktop-$(VERSION).tar.gz
	mkdir -p /tmp/rdesktop-make-dist-dir
	tar zxvf $< -C /tmp/rdesktop-make-dist-dir
	mv /tmp/rdesktop-make-dist-dir/rdesktop-$(VERSION) /tmp/rdesktop-make-dist-dir/rdesktop
	ls /tmp/rdesktop-make-dist-dir/rdesktop
	tar zcvf $@ -C /tmp/rdesktop-make-dist-dir rdesktop
	rm -rf /tmp/rdesktop-make-dist-dir

Makefile: Makefile.in configure
	./config.status

configure: configure.ac
	./bootstrap

.SUFFIXES:
.SUFFIXES: .c .o .m

.c.o:
	$(CC) $(CFLAGS) -o $@ -c $<

.m.o:
	$(CC) $(CFLAGS) -o $@ -c $<

.PHONY: doc/AUTHORS
doc/AUTHORS:
	./genauthors *.c
